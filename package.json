{
  "name": "cykani",
  "private": true,
  "scripts": {
    "dev": "turbo run dev --filter=@cykani/api --filter=cykani",
    "dev:api": "pnpm --filter @cykani/api dev",
    "dev:web": "pnpm --filter ./apps/web dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:push": "cd apps/api && npx drizzle-kit push",
    "db:studio": "cd apps/api && npx drizzle-kit studio"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}