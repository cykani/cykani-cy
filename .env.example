# ── Database ──────────────────────────────────────────
# Local:   postgresql://postgres:1234@postgres:5432/cykani
# Neon:    postgresql://user:pass@ep-xxxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# ── Redis ─────────────────────────────────────────────
# Local:   redis://redis:6379
# Upstash: redis://default:pass@xxxx.upstash.io:6379
REDIS_URL=redis://redis:6379

# ── API ───────────────────────────────────────────────
JWT_SECRET=
API_KEY_SECRET=
CORS_ORIGINS=http://localhost:3001

# ── Auth (NextAuth) ──────────────────────────────────
AUTH_SECRET=
AUTH_URL=http://localhost:3001
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ── Payments ──────────────────────────────────────────
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Optional ──────────────────────────────────────────
DOCKER_SOCKET=/var/run/docker.sock
BROWSER_IMAGE=cykani-browser:latest
MAX_SESSIONS_PER_ORG=10
LOG_LEVEL=info
NODE_ENV=production
