# cykani API Environment Variables

# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cykani

# Redis
REDIS_URL=redis://localhost:6379

# Valkey (optional — takes precedence over REDIS_URL if set)
# VALKEY_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-to-a-random-32-char-string
API_KEY_SECRET=change-me-to-a-random-32-char-string
API_KEY_PREFIX=ck_

# CORS (comma-separated origins, e.g. "https://app.cykani.com,https://cykani.com")
# Leave empty in development for localhost:3000/3001 fallback
CORS_ORIGINS=

# Browser
DOCKER_SOCKET=/var/run/docker.sock
BROWSER_IMAGE=cykani-browser:latest
MAX_SESSIONS_PER_ORG=10
SESSION_TIMEOUT_MINUTES=30

# VNC
VNC_BASE_PORT=5900
VNC_WS_PORT=6080
# VNC_PROXY_URL=http://localhost:6080

# Email (Listmonk — optional)
# EMAIL_API_URL=http://localhost:9000
# EMAIL_API_KEY=<listmonk-api-key>

# Stripe (optional)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Logging
LOG_LEVEL=info
